datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String
  status    String   @default("APPROVED") // APPROVED, PENDING, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization?
  individualDonor IndividualDonor?
  volunteer       Volunteer?
  ngo             Ngo?
  notifications   Notification[]
}

model Organization {
  id            String     @id @default(uuid())
  userId        String     @unique
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  contactPerson String
  mobile        String
  address       String
  orgType       String // Hotel, Restaurant, Event Organizer, Marriage Hall, Catering Service, Bakery, College Mess, Corporate Office, Religious Organization
  openingTime   String
  closingTime   String
  logoUrl       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  donations     Donation[]
}

model IndividualDonor {
  id           String     @id @default(uuid())
  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  mobile       String
  address      String
  profilePhoto String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  donations    Donation[]
}

model Volunteer {
  id            String               @id @default(uuid())
  userId        String               @unique
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName      String
  mobile        String
  address       String
  city          String
  district      String
  state         String
  pincode       String
  currentLat    Float?
  currentLng    Float?
  gender        String
  dob           String
  govIdNumber   String
  idProofUrl    String?
  profilePhoto  String?
  vehicleType   String // Bike, Scooter, Bicycle, Car, Walking
  vehicleNumber String?
  availability  String // Morning, Afternoon, Evening, Night
  status        String               @default("AVAILABLE")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  assignments   DeliveryAssignment[]
}

model Ngo {
  id                String               @id @default(uuid())
  userId            String               @unique
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  contactPerson     String
  mobile            String
  address           String
  logoUrl           String?
  regCertificateUrl String?
  govApprovalUrl    String?
  documentStatus    String               @default("PENDING") // APPROVED, PENDING, REJECTED
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  assignments       DeliveryAssignment[]
}

model Donation {
  id             String   @id @default(uuid())
  foodName       String
  description    String
  category       String // Vegetarian, Non-Vegetarian, Mixed
  quantity       Int // Number of meals
  readyTime      String
  expiryTime     String
  pickupAddress  String
  foodImageUrl   String?
  notes          String?
  status         String   @default("PENDING")
  calories       Int?
  protein        Int?
  carbs          Int?
  fat            Int?
  nutritionScore Int?
  qrCodeText     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orgDonorId String?
  orgDonor   Organization?    @relation(fields: [orgDonorId], references: [id])
  indDonorId String?
  indDonor   IndividualDonor? @relation(fields: [indDonorId], references: [id])

  assignments DeliveryAssignment[]
}

model DeliveryAssignment {
  id          String     @id @default(uuid())
  donationId  String
  donation    Donation   @relation(fields: [donationId], references: [id], onDelete: Cascade)
  ngoId       String
  ngo         Ngo        @relation(fields: [ngoId], references: [id])
  volunteerId String?
  volunteer   Volunteer? @relation(fields: [volunteerId], references: [id])

  destinationType    String // HOSPITAL, SHELTER, NEEDY_AREA
  destinationName    String
  destinationAddress String
  hospitalId         String?
  hospital           Hospital?      @relation(fields: [hospitalId], references: [id])
  needyLocationId    String?
  needyLocation      NeedyLocation? @relation(fields: [needyLocationId], references: [id])

  status    String   @default("AVAILABLE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proof    DeliveryProof?
  tracking DeliveryTracking[]
}

model DeliveryProof {
  id                String             @id @default(uuid())
  assignmentId      String             @unique
  assignment        DeliveryAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  photoUrl          String
  recipientPhotoUrl String?
  notes             String?
  verified          Boolean            @default(false)
  verifiedAt        DateTime?
  createdAt         DateTime           @default(now())
}

model DeliveryTracking {
  id           String             @id @default(uuid())
  assignmentId String
  assignment   DeliveryAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  latitude     Float
  longitude    Float
  timestamp    DateTime           @default(now())
}

model Hospital {
  id            String               @id @default(uuid())
  name          String
  address       String
  contactPerson String
  mobile        String
  createdAt     DateTime             @default(now())
  assignments   DeliveryAssignment[]
}

model NeedyLocation {
  id            String               @id @default(uuid())
  name          String
  address       String
  description   String?
  contactPerson String?
  mobile        String?
  createdAt     DateTime             @default(now())
  assignments   DeliveryAssignment[]
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String // DONATION_REQUEST, STATUS_UPDATE, GENERAL
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmergencyRequest {
  id            String   @id @default(uuid())
  ngoId         String
  mealsRequired Int
  location      String
  foodType      String // Vegetarian, Non-Vegetarian, Mixed
  deadline      String
  status        String   @default("PENDING") // PENDING, FULFILLED
  priorityLevel String   @default("MEDIUM") // LOW, MEDIUM, HIGH, SOS
  createdAt     DateTime @default(now())
}

model WasteAnalytic {
  id        String   @id @default(uuid())
  donorId   String
  foodItem  String
  quantity  Int
  costLoss  Float
  dayOfWeek String
  createdAt DateTime @default(now())
}

model AIPrediction {
  id            String   @id @default(uuid())
  donorId       String
  customerCount Int
  dayOfWeek     String
  eventType     String
  predictedQty  Int
  suggestedTime String
  confidence    Float
  createdAt     DateTime @default(now())
}

model DonationSchedule {
  id         String   @id @default(uuid())
  donorId    String
  frequency  String // DAILY, WEEKLY, ONCE
  dayOfWeek  String?
  pickupTime String
  foodName   String
  category   String
  quantity   Int
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model CommunityFridge {
  id             String   @id @default(uuid())
  name           String
  location       String
  latitude       Float
  longitude      Float
  capacity       Int
  currentMeals   Int
  lastRefillTime DateTime @default(now())
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
}

model VolunteerAchievement {
  id          String @id @default(uuid())
  volunteerId String @unique
  deliveries  Int    @default(0)
  distance    Float  @default(0.0)
  hours       Float  @default(0.0)
  points      Int    @default(0)
  badges      String // JSON string array of badges
}

model Referral {
  id            String   @id @default(uuid())
  referrerId    String
  referredEmail String
  role          String
  status        String   @default("PENDING") // PENDING, JOINED
  rewardPoints  Int      @default(0)
  createdAt     DateTime @default(now())
}

model ColdStorage {
  id           String  @id @default(uuid())
  name         String
  location     String
  temperature  Float   @default(4.0)
  capacity     Int
  currentMeals Int
  expiryAlerts Boolean @default(false)
}
